{
  "epic_id": "04_knowledge_plane_and_artifacts",
  "objective": "Stand up Layer 4 decomposition and Layer 5 canonical artifact flow with explicit anchor, revision, and re-ingestion contracts.",
  "dependencies": [
    "03_graphiti_neo4j_durable_memory",
    "docs/design/knowledge-and-artifact-architecture.md"
  ],
  "workstreams": [
    {
      "id": "01",
      "name": "Anchor and revision model",
      "outputs": [
        "stable anchor identity",
        "revision linkage",
        "dirty-state and publication status"
      ]
    },
    {
      "id": "02",
      "name": "Layer 4 decomposition",
      "outputs": [
        "typed slices",
        "source locators",
        "embeddings and lexical fields",
        "retrieval-ready payloads"
      ]
    },
    {
      "id": "03",
      "name": "Canonical artifact flow",
      "outputs": [
        "Git or provider-backed canonical source",
        "redraft and publication loop",
        "re-ingestion after revision changes"
      ]
    }
  ],
  "exit_criteria": [
    "Artifacts have stable anchor and revision identity.",
    "Layer 4 remains revision-aware and source-linked.",
    "Layer 5 remains canonical publication truth."
  ],
  "risks": [
    "Allowing Layer 4 slices to masquerade as canonical artifacts.",
    "Failing to invalidate stale Layer 3 support after revision changes."
  ]
}
